# Scene understanding (splits script, picks visual type per scene)
ANTHROPIC_API_KEY=

# Voiceover word-timestamp alignment (Whisper transcription endpoint)
OPENAI_API_KEY=

# Stock footage search (at least one of these two)
PEXELS_API_KEY=
PIXABAY_API_KEY=

# AI generation fallback for scenes with no good stock match
STABILITY_API_KEY=
RUNWAY_API_KEY=

# Text-to-speech, for generating a voiceover instead of uploading one
ELEVENLABS_API_KEY=
GOOGLE_TTS_API_KEY=

# Optional: only needed for YouTube transcript import when hosted on a
# cloud platform (YouTube blocks most datacenter IPs, including Render's).
# A cheap Webshare rotating-residential proxy plan (~$1/month) fixes it.
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
